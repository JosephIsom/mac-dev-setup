{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "TypeScript: typecheck",
      "type": "shell",
      "command": "tsc",
      "args": [
        "--noEmit"
      ],
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "TypeScript: npm test",
      "type": "shell",
      "command": "npm",
      "args": [
        "test"
      ],
      "group": "test",
      "problemMatcher": []
    }
  ]
}
