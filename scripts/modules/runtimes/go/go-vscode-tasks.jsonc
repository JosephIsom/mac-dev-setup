{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Go: test ./...",
      "type": "shell",
      "command": "go",
      "args": [
        "test",
        "./..."
      ],
      "group": "test",
      "problemMatcher": "$go"
    },
    {
      "label": "Go: golangci-lint",
      "type": "shell",
      "command": "golangci-lint",
      "args": [
        "run"
      ],
      "group": "build",
      "problemMatcher": "$go"
    }
  ]
}
