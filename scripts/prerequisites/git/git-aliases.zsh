# shellcheck shell=bash
# Git aliases (mac-dev-setup)
alias gs='git status -sb'
alias ga='git add'
alias gc='git commit'
alias gco='git checkout'
alias gsw='git switch'
alias gswc='git switch -c'
alias gb='git branch'
alias gl='git log --oneline --decorate --graph -20'
alias gd='git diff'
alias grs='git restore'
alias gp='git pull'
alias gps='git push'
